{
  "name": "job-application-tracker",
  "version": "1.0.0",
  "description": "AI-powered job application tracking with Kanban board",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
